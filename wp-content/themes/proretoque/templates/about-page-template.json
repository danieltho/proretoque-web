              }
            },
            {
              "id": "w_hero_divider",
              "elType": "widget",
              "widgetType": "divider",
              "settings": {
                "color": "#000000",
                "weight": {"size": 2, "unit": "px"},
                "gap": {"size": 20, "unit": "px"}
